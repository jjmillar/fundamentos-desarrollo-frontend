<!DOCTYPE html>
<html lang="es">

    <head>

        <meta charset="UTF-8">
        <title>El Juego</title>
        <link rel="stylesheet" href="/CSS/style.css">

    </head>

    <body>
        <%- include("partials/nav") %>
        <div class="contenedor">

            <h1>Adivina el Número</h1>
            <h2>Jugador: <%= nombre %></h2>
            <p>Intentos utilizados: <%= intentos %></p>
            <p>Intentos restantes: <%= restantes %></p>
            <p><%= mensaje %></p>

            <form action="/intento" method="POST">

                <input type="number" name="numero" min="1" max="10" required >
                <button> Intentar </button>

            </form>

        </div>

    </body>

</html>