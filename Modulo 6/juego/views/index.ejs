<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Adivina el Número</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-5 border-0">
          <div class="card-body p-4">
            <h1 class="text-center mb-3">Adivina el Número</h1>
            <p class="text-muted text-center">
              Se generará un número secreto entre 1 y 10.
              Tendrás un máximo de 5 intentos para adivinarlo.
            </p>
            <% if (error) { %>
              <div class="alert alert-danger py-2" role="alert">
                <%= error %>
              </div>
            <% } %>

            <form action="/iniciar" method="POST">
              <div class="mb-3">
                <label for="nombre" class="form-label">Tu nombre</label>
                <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Escribe tu nombre" required>
              </div>
              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Comenzar partida</button>
                <a href="/historial" class="btn btn-secondary">Ver historial de juegos</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
