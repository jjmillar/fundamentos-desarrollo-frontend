<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Historial - Adivina el Número</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-9 col-lg-8">
        <div class="card shadow-sm mt-5 border-0">
          <div class="card-body p-4">
            <h1 class="text-center mb-4">Historial de Partidas</h1>

            <div class="row text-center mb-4 g-3">
              <div class="col-6 col-md-3">
                <div class="p-3 bg-light border rounded">
                  <div class="fs-4 fw-bold"><%= totalPartidas %></div>
                  <div class="small text-muted">Partidas</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="p-3 bg-light border rounded">
                  <div class="fs-4 fw-bold text-success"><%= partidasGanadas %></div>
                  <div class="small text-muted">Ganadas</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="p-3 bg-light border rounded">
                  <div class="fs-4 fw-bold text-danger"><%= partidasPerdidas %></div>
                  <div class="small text-muted">Perdidas</div>
                </div>
              </div>
              <div class="col-6 col-md-3">
                <div class="p-3 bg-light border rounded">
                  <div class="fs-4 fw-bold text-primary"><%= puntajeTotal %></div>
                  <div class="small text-muted">Puntaje total</div>
                </div>
              </div>
            </div>

            <% if (partidas.length === 0) { %>
              <p class="text-center text-muted">Aún no hay partidas registradas.</p>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                  <thead class="table-dark">
                    <tr>
                      <th>#</th>
                      <th>Nombre del jugador</th>
                      <th>Puntaje</th>
                      <th>Fecha</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% partidas.forEach((p, i) => { %>
                      <tr>
                        <td><%= i + 1 %></td>
                        <td><%= p.nombre %></td>
                        <td><%= p.puntaje %></td>
                        <td><%= p.fecha %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>

            <div class="d-grid mt-4">
              <a href="/" class="btn btn-primary">Volver a la página principal</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
