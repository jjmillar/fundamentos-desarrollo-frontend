<%- include('partials/header', { titulo: 'Inicio' }) %>

<div class="container pb-5">
    <h1 class="text-center mb-4">
        Sistema de Arriendo de Bicicletas
    </h1>
    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="row text-center g-3 mb-3">
                <div class="col-md-6">
                    <div class="border rounded p-3">
                        <div class="text-muted">Bicicletas disponibles</div>
                        <div class="fs-2 text-primary fw-bold"><%= disponibles %></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border rounded p-3">
                        <div class="text-muted">Bicicletas arrendadas</div>
                        <div class="fs-2 text-success fw-bold"><%= arrendadas %></div>
                    </div>
                </div>
            </div>
            <% if(disponibles > 10){ %>
                <div class="alert alert-success mb-0">
                    <%= mensaje %>
                </div>
            <% } else if(disponibles >= 5){ %>
                <div class="alert alert-warning mb-0">
                    <%= mensaje %>
                </div>
            <% } else { %>
                <div class="alert alert-danger mb-0">
                    <%= mensaje %>
                </div>
            <% } %>
            <div class="mt-4">
                <a href="/arrendar" class="btn btn-secondary">
                    Arrendar bicicleta
                </a>
                <a href="/devolver" class="btn btn-secondary">
                    Devolver bicicleta
                </a>
            </div>
        </div>
    </div>
    <div class="card shadow">
        <div class="card-body">
            <h5 class="mb-3">Detalle de bicicletas arrendadas</h5>
            <% if(arriendos.length === 0){ %>
                <p class="text-muted mb-0">
                    No hay bicicletas arrendadas actualmente.
                </p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Cliente</th>
                                <th>Cantidad</th>
                                <th>Fecha de arriendo</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% arriendos.forEach((a, i) => { %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td><%= a.cliente %></td>
                                    <td><%= a.cantidad %></td>
                                    <td><%= a.fecha %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary">
                                <th colspan="2">Total</th>
                                <th><%= arrendadas %></th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>