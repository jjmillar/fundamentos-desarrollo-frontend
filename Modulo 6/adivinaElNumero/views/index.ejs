<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Adivina el Número</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <h1>Adivina el Número</h1>

    <p>
        Debes adivinar un número entre 1 y 10.
        Tienes un máximo de cinco intentos.
    </p>

    <form action="/" method="POST">

        <label>Nombre del jugador:</label>

        <input
            type="text"
            name="nombre">

        <button type="submit">
            Comenzar
        </button>

    </form>

    <p style="color:red;">
        <%= error %>
    </p>

    <a href="/historial">
        Ver historial
    </a>

</body>
</html>